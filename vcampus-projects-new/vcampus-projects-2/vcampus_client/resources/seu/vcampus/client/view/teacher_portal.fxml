<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="650" minWidth="950" prefHeight="650" prefWidth="950" stylesheets="@../css/teacher_portal.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.vcampus.client.controller.TeacherPortalController">
    <!-- 顶部标题栏：移除"止于至善"文字 -->
    <top>
        <HBox fx:id="titleBar" prefHeight="50.0" styleClass="title-bar" BorderPane.alignment="CENTER">
            <children>
                <!-- 校徽 -->
                <ImageView fx:id="schoolBadge" fitHeight="32" fitWidth="32" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../images/xiaohui.png" />
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </ImageView>
                
                <!-- V-Campus按钮 -->
                <Button fx:id="vcampusButton" mnemonicParsing="false" styleClass="vcampus-title" text="V-Campus">
                    <padding>
                        <Insets left="10.0" right="10.0" />
                    </padding>
                </Button>
                
                <!-- 占位区域，保持原布局对称性 -->
                <Region HBox.hgrow="ALWAYS" />
                
                
                <!-- 占位区域，保持原布局对称性 -->
                <Region HBox.hgrow="ALWAYS" />
                
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button fx:id="minimizeButton" mnemonicParsing="false" onAction="#handleMinimize" styleClass="minimize-button">
                            <graphic>
                                <SVGPath content="M6,12 H14" styleClass="minimize-icon" />
                            </graphic>
                        </Button>
                        <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" styleClass="close-button">
                            <graphic>
                                <SVGPath content="M7,7 L13,13 M13,7 L7,13" styleClass="close-icon" />
                            </graphic>
                        </Button>
                    </children>
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </HBox>
            </children>
        </HBox>
    </top>
    
    <!-- 左侧区域：保持不变 -->
    <left>
        <StackPane fx:id="leftStack" prefWidth="150.0" prefHeight="600.0" styleClass="left-stack">
            <VBox fx:id="sidebarContainer" prefWidth="150.0" prefHeight="600.0" styleClass="sidebar" VBox.vgrow="ALWAYS" />
            <VBox fx:id="appSidebar" prefWidth="150.0" prefHeight="600.0" styleClass="app-sidebar" visible="false" />
        </StackPane>
    </left>
    
    <!-- 中间内容区：保持不变 -->
    <center>
        <VBox fx:id="contentArea" prefHeight="600.0" prefWidth="800.0" styleClass="content-area" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS" />
    </center>
</BorderPane>
    