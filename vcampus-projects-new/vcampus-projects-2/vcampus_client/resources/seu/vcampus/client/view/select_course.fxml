<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="800.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" styleClass="background" stylesheets="@../css/edu_admin.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.vcampus.client.controller.CourseSelectController">
   <top>
      <VBox minHeight="200.0" prefHeight="200.0" prefWidth="800.0" BorderPane.alignment="CENTER">
         <children>
            <AnchorPane maxWidth="800.0" minHeight="100.0" prefHeight="100.0" prefWidth="800.0">
               <children>
                  <HBox layoutX="30.0" layoutY="30.0" maxHeight="80.0" prefHeight="70.0" prefWidth="740.0" styleClass="card-background">
                     <children>
                        <AnchorPane prefHeight="80.0" prefWidth="30.0">
                           <children>
                              <ImageView fitHeight="20.0" fitWidth="20.0" layoutX="10.0" layoutY="25.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../images/magnifyingGlass.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </AnchorPane>
                        <AnchorPane minWidth="480.0" prefHeight="80.0" prefWidth="520.0">
                           <children>
                              <TextField fx:id="nameText" layoutX="5.0" layoutY="17.0" prefHeight="36.0" prefWidth="510.0" promptText="搜索课程" styleClass="textField">
                                 <font>
                                    <Font size="14.0" />
                                 </font></TextField>
                           </children>
                        </AnchorPane>
                        <AnchorPane minWidth="100.0" prefHeight="80.0" prefWidth="190.0">
                           <children>
                              <Button fx:id="search" layoutX="5.0" layoutY="17.0" mnemonicParsing="false" onAction="#OnSearchClick" prefHeight="36.0" prefWidth="85.0" styleClass="my-button" text="搜索">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Button>
                              <Button fx:id="refresh" layoutX="100.0" layoutY="17.0" mnemonicParsing="false" onAction="#OnRefreshClick" prefHeight="36.0" prefWidth="80.0" styleClass="my-button" text="刷新">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Button>
                           </children>
                        </AnchorPane>
                     </children>
                  </HBox>
               </children>
            </AnchorPane>
            <AnchorPane maxHeight="100.0" minHeight="100.0" prefHeight="100.0" prefWidth="800.0">
               <children>
                  <HBox layoutX="30.0" layoutY="20.0" prefHeight="70.0" prefWidth="740.0" styleClass="card-background">
                     <children>
                        <AnchorPane prefHeight="80.0" prefWidth="66.0">
                           <children>
                              <Label layoutX="10.0" layoutY="26.0" styleClass="my-label" text="课程性质">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                           </children>
                        </AnchorPane>
                        <AnchorPane maxWidth="301.0" minWidth="290.0" prefHeight="80.0" prefWidth="301.0">
                           <children>
                              <ComboBox fx:id="courseNature" layoutX="5.0" layoutY="17.0" prefHeight="36.0" prefWidth="294.0" styleClass="combobox" />
                           </children>
                        </AnchorPane>
                        <AnchorPane layoutX="10.0" prefHeight="80.0" prefWidth="61.0">
                           <children>
                              <Label layoutX="5.0" layoutY="26.0" styleClass="my-label" text="开课单位">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                           </children>
                        </AnchorPane>
                        <AnchorPane prefHeight="80.0" prefWidth="312.0">
                           <children>
                              <ComboBox fx:id="courseDepartment" layoutX="5.0" layoutY="17.0" maxWidth="297.0" prefHeight="36.0" prefWidth="297.0" styleClass="combobox" />
                           </children>
                           <padding>
                              <Insets right="10.0" />
                           </padding>
                        </AnchorPane>
                     </children>
                  </HBox>
               </children>
            </AnchorPane>
         </children>
      </VBox>
   </top>
   <center>
      <AnchorPane maxHeight="400.0" maxWidth="800.0" minHeight="400.0" minWidth="800.0" prefHeight="400.0" prefWidth="800.0" BorderPane.alignment="CENTER">
         <children>
         <ScrollPane fitToHeight="true" fitToWidth="false" layoutX="30.0" layoutY="10.0" prefHeight="360.0" prefWidth="740.0" styleClass="my-scroll">
         <content>
            <TableView fx:id="course_scheduled" layoutX="30.0" layoutY="10.0" prefHeight="360.0" prefWidth="740.0" styleClass="my-tableview">
              <columns>
                <TableColumn fx:id="courseID" maxWidth="135.0" minWidth="135.0" prefWidth="135.0" text="课程号" />
                <TableColumn fx:id="courseName" prefWidth="230.0" text="课程名称" />
                  <TableColumn fx:id="credit" prefWidth="75.0" text="学分" />
                  <TableColumn fx:id="nature" prefWidth="75.0" text="性质" />
                  <TableColumn fx:id="department" prefWidth="225.0" text="开课单位" />
              </columns>
            </TableView>
            </content>
               </ScrollPane>
         </children>
      </AnchorPane>
   </center>
</BorderPane>
