<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="seu.vcampus.client.controller.ChangePasswordController"
            stylesheets="@../css/student_portal.css">
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            
            <Label text="修改密码" style="-fx-text-fill: #116ecd; -fx-font-size: 24px; -fx-font-weight: bold;">
                <padding>
                    <Insets bottom="20"/>
                </padding>
            </Label>
            
            <GridPane hgap="10" vgap="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 30;">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" prefWidth="100"/>
                    <ColumnConstraints halignment="LEFT" prefWidth="250"/>
                </columnConstraints>
                
                <rowConstraints>
                    <RowConstraints prefHeight="35"/>
                    <RowConstraints prefHeight="35"/>
                    <RowConstraints prefHeight="35"/>
                    <RowConstraints prefHeight="35"/>
                </rowConstraints>
                
                <!-- 原密码 -->
                <Label text="原密码:" GridPane.rowIndex="0" GridPane.columnIndex="0" 
                       style="-fx-text-fill: #444; -fx-font-size: 14px;"/>
                <PasswordField fx:id="oldPasswordField" GridPane.rowIndex="0" GridPane.columnIndex="1" 
                               style="-fx-pref-height: 35; -fx-background-radius: 5; -fx-border-radius: 5;"/>
                
                <!-- 新密码 -->
                <Label text="新密码:" GridPane.rowIndex="1" GridPane.columnIndex="0" 
                       style="-fx-text-fill: #444; -fx-font-size: 14px;"/>
                <PasswordField fx:id="newPasswordField" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                               style="-fx-pref-height: 35; -fx-background-radius: 5; -fx-border-radius: 5;"/>
                
                <!-- 确认新密码 -->
                <Label text="确认新密码:" GridPane.rowIndex="2" GridPane.columnIndex="0" 
                       style="-fx-text-fill: #444; -fx-font-size: 14px;"/>
                <PasswordField fx:id="confirmPasswordField" GridPane.rowIndex="2" GridPane.columnIndex="1" 
                               style="-fx-pref-height: 35; -fx-background-radius: 5; -fx-border-radius: 5;"/>
                
                <!-- 按钮区域 -->
                <HBox spacing="20" GridPane.rowIndex="3" GridPane.columnIndex="1" 
                      alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                    <Button fx:id="submitButton" text="确认修改" 
                            style="-fx-background-color: #116ecd; -fx-text-fill: white; -fx-pref-width: 100; 
                                   -fx-pref-height: 35; -fx-background-radius: 5;"/>
                    <Button fx:id="resetButton" text="重置" 
                            style="-fx-background-color: #a0a0a0; -fx-text-fill: white; -fx-pref-width: 100; 
                                   -fx-pref-height: 35; -fx-background-radius: 5;"/>
                </HBox>
            </GridPane>
            
            <!-- 状态消息 -->
            <Label fx:id="statusLabel" style="-fx-text-fill: #e53935; -fx-font-size: 14px;"/>
        </VBox>
    </center>
</BorderPane>