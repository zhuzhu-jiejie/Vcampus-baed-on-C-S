<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<?import javafx.scene.control.*?>

<ScrollPane fx:id="scrollPane" fitToWidth="true" prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/student_status.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.vcampus.client.controller.AdminStatusChangeController">
   <content>
   	  <!-- 最外层的VBox容器 -->
      <VBox styleClass="background">
         <children>
          
            <VBox styleClass="card-background">
               <children>
                  <HBox styleClass="card-title-bar">
                     <children>
                        <Label styleClass="card-title" text="申请列表" />
                     </children>
                  </HBox>
                  <GridPane hgap="5" style="-fx-padding: 5;" vgap="1">
            		<columnConstraints>
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
            		</columnConstraints>
            		<rowConstraints>
                		<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            		</rowConstraints>
            		<children>
                		<Label styleClass="info-key-text" text="按姓名：" GridPane.columnIndex="2" />
                		<Label styleClass="info-key-text" text="按学号：" />
            			<Label styleClass="info-key-text" text="按类型：" GridPane.rowIndex="1" />
            			<TextField fx:id="byName" styleClass="my-textarea" GridPane.columnIndex="3" />
            			<ComboBox fx:id="byType" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <TextField fx:id="byStudentId" styleClass="my-textarea" GridPane.columnIndex="1" />
                        <Label styleClass="info-key-text" text="按状态：" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <ComboBox fx:id="byStatus" styleClass="my-combo-box" GridPane.columnIndex="3" GridPane.rowIndex="1" />
           			</children>
        		  </GridPane>
                  <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="50.0" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="retrieve" mnemonicParsing="false" onAction="#handleRetrieve" styleClass="my-button" text="检索" />
                        <Button fx:id="conditionClearButton" mnemonicParsing="false" onAction="#handleClearCondition" styleClass="my-button" text="清空条件" />
                     </children>
                  </HBox>
                  
                  <!-- 加载提示 -->
                  <HBox alignment="CENTER" prefHeight="30.0" spacing="10.0" style="-fx-padding: 0 5 5 5;">
                     <children>
                        <!-- 加载提示：初始隐藏，显示时用旋转图标增强视觉效果 -->
                        <Label fx:id="loadingLabel" text="加载中..." visible="false">
                           <graphic>
                              <ProgressIndicator prefHeight="16.0" prefWidth="16.0" style="-fx-progress-color: #2196f3;" />
                           </graphic>
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin>
                        </Label>
                        <!-- 错误/成功提示：初始隐藏，红色=错误，绿色=成功 -->
                        <Label fx:id="errorLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 13px;" text="" visible="false" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="applicationList" styleClass="my-table-view">
                    <columns>
                      	<TableColumn fx:id="studentIdCol" prefWidth="92.0" text="申请人学号" />
                      	<TableColumn fx:id="nameCol" prefWidth="93.0" text="申请人姓名" />
                        <TableColumn fx:id="typeCol" prefWidth="85.0" text="申请类型" />
                        <TableColumn fx:id="dateCol" prefWidth="85.0" text="申请时间" />
                        <TableColumn fx:id="reasonCol" prefWidth="257.0" text="申请原因" />
                        <TableColumn fx:id="statusCol" prefWidth="103.0" text="当前状态" />
                    </columns>
                     <VBox.margin>
                        <Insets left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                  </TableView>
               </children>
            </VBox>
            
			<VBox styleClass="card-background">
               <children>
                  <HBox styleClass="card-title-bar">
                     <children>
                        <Label styleClass="card-title" text="申请详情" />
                     </children>
                  </HBox>
                  <VBox fx:id="applicationForm" maxWidth="Infinity" VBox.vgrow="ALWAYS" />
                  <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="50.0" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="deselect" layoutX="233.0" layoutY="16.0" mnemonicParsing="false" onAction="#handleDeselect" styleClass="my-button" text="取消选中" />
                        <Button fx:id="pass" layoutX="563.0" layoutY="16.0" mnemonicParsing="false" onAction="#handlePass" styleClass="my-button" text="通过申请" />
                        <Button fx:id="refuse" layoutX="563.0" layoutY="16.0" mnemonicParsing="false" onAction="#handleRefuse" styleClass="my-button" text="拒绝申请" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
         </children></VBox>
   </content>
</ScrollPane>
