<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<!-- 移除了不存在的背景图片配置，确保基础布局正确 -->
<!-- 开头：用>代替/>，表示开始标签 -->
<BorderPane fx:id="mainBorderPane" prefHeight="600" prefWidth="800" 
            xmlns="http://javafx.com/javafx/8" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="seu.vcampus.client.controller.LibraryBorrowController">

    <!-- 中间的<top>、<center>、<bottom>等子元素 -->
    <!-- ... 此处省略子元素代码 ... -->


    
    <!-- 顶部搜索区域 -->
    <top>
        <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <Label style="-fx-text-fill: #34495e; -fx-font-weight: bold; -fx-font-size: 16px;" text="图书馆借阅系统" />
                    </children>
                </HBox>
                
                <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15 0 0 0;">
                    <children>
                        <TextField fx:id="searchField" promptText="输入书名或作者" style="-fx-pref-width: 300px; -fx-pref-height: 35px;" />
                        <Button fx:id="searchButton" mnemonicParsing="false" onAction="#handleSearch" style="-fx-pref-width: 80px; -fx-pref-height: 35px; -fx-background-color: #3498db; -fx-text-fill: white;" text="搜索" />
                        <Button fx:id="clearButton" mnemonicParsing="false" onAction="#handleClear" style="-fx-pref-width: 80px; -fx-pref-height: 35px; -fx-background-color: #95a5a6; -fx-text-fill: white;" text="清空" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    
    <!-- 中央内容区域 -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;">
           <content>
               <VBox spacing="20" style="-fx-padding: 20;">
                  <children>
                      <!-- 搜索结果统计 -->
                      <HBox>
                         <children>
                             <Label fx:id="resultCountLabel" style="-fx-text-fill: #34495e; -fx-font-weight: bold;" text="找到 0 本相关书籍" />
                         </children>
                      </HBox>
                     
                      <!-- 书籍列表容器 -->
                      <VBox fx:id="booksContainer" spacing="15" />
                  </children>
               </VBox>
           </content>
        </ScrollPane>
    </center>
    
    <!-- 底部状态栏 -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <children>
                <Label fx:id="statusLabel" style="-fx-text-fill: #2c3e50;" text="准备就绪" />
            </children>
        </HBox>
    </bottom>
    
</BorderPane>