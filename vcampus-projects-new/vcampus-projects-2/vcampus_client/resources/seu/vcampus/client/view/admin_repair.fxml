<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../css/admin_repair.css" 
fx:controller="seu.vcampus.client.controller.AdminRepairController">
    <center>
        <!-- 报修管理卡片 -->
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-pref-width: 800;">
                <HBox style="-fx-background-color: #3498db; -fx-background-radius: 10 10 0 0; -fx-padding: 15;">
                    <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="报修申请管理" />
                </HBox>
                
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="refreshBtn" onAction="#handleRefresh" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 80;" text="刷新" />
                        <Button fx:id="processBtn" onAction="#handleProcessRepair" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 100;" text="标记处理" />
                    </HBox>
                    
                    <TableView fx:id="repairTable" style="-fx-pref-height: 300;">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="60" text="ID" />
                            <TableColumn fx:id="dormBuildingColumn" prefWidth="80" text="宿舍楼" />
                            <TableColumn fx:id="dormRoomColumn" prefWidth="80" text="房间号" />
                            <TableColumn fx:id="descriptionColumn" prefWidth="250" text="报修描述" />
                            <TableColumn fx:id="statusColumn" prefWidth="80" text="状态" />
                            <TableColumn fx:id="dateColumn" prefWidth="100" text="申请日期" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>