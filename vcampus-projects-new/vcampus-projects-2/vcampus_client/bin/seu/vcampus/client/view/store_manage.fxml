<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="900.0" stylesheets="@../css/store_manage.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" 
fx:controller="seu.vcampus.client.controller.StoreManageController">
    <top>
        <!-- 顶部导航栏 -->
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="商品管理" />
            
            <HBox spacing="15" style="-fx-padding: 0 0 0 30;">
                <Button mnemonicParsing="false" onAction="#handleNavigateToOrders" style="-fx-nav-button;" text="订单管理" />
                <Button mnemonicParsing="false" onAction="#handleNavigateToUsers" style="-fx-nav-button;" text="用户管理" />
                <Button mnemonicParsing="false" onAction="#handleNavigateToReports" style="-fx-nav-button;" text="报表统计" />
                <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-nav-button;" text="退出登录" />
            </HBox>
        </HBox>
        
        <!-- 搜索和筛选栏 -->
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #34495e; -fx-padding: 15;">
            <TextField fx:id="searchField" promptText="搜索商品..." style="-fx-search-field;" />
            <ComboBox fx:id="categoryFilter" promptText="选择分类" style="-fx-filter-combo;" />
            <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-filter-button;" text="搜索" />
            <Button mnemonicParsing="false" onAction="#handleClearFilter" style="-fx-filter-button;" text="清除筛选" />
        </HBox>
    </top>
    
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <!-- 商品表格 -->
            <VBox spacing="10" style="-fx-pref-width: 700;">
                <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 16;" text="商品列表" />
                <TableView fx:id="productsTable" style="-fx-products-table;">
                    <columns>
                        <TableColumn fx:id="colId" text="商品ID" />
                        <TableColumn fx:id="colName" text="商品名称" />
                        <TableColumn fx:id="colPrice" text="价格" />
                        <TableColumn fx:id="colCategory" text="分类" />
                    </columns>
                </TableView>
            </VBox>
            
            <!-- 商品表单 -->
            <VBox spacing="15" style="-fx-pref-width: 400;">
                <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 16;" text="商品信息" />
                
                <TextField fx:id="productIdField" promptText="商品ID" style="-fx-form-field;" />
                <TextField fx:id="productNameField" promptText="商品名称" style="-fx-form-field;" />
                <TextField fx:id="productPriceField" promptText="价格" style="-fx-form-field;" />
                <TextField fx:id="productOriginalPriceField" promptText="原价" style="-fx-form-field;" />
                <ComboBox fx:id="productCategoryField" promptText="选择分类" style="-fx-form-field;" />
                <TextArea fx:id="productDescriptionField" promptText="商品描述" style="-fx-form-textarea;" />
                
                <HBox spacing="10">
                    <Button fx:id="addButton" mnemonicParsing="false" onAction="#handleAddProduct" style="-fx-primary-button;" text="添加" />
                    <Button fx:id="updateButton" mnemonicParsing="false" onAction="#handleUpdateProduct" style="-fx-primary-button;" text="更新" />
                    <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDeleteProduct" style="-fx-danger-button;" text="删除" />
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>