<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox styleClass="new-background" stylesheets="@../css/student_status.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.vcampus.client.controller.AbsenceFormController">
    <children>
        <HBox styleClass="card-title-bar">
            <children>
                <Label styleClass="card-title" text="休学申请表" />
            </children>
        </HBox>
        <GridPane hgap="5" style="-fx-padding: 5;" vgap="1">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label styleClass="info-key-text" text="姓名：" GridPane.columnIndex="0" />
                <Label styleClass="info-key-text" text="学号：" GridPane.columnIndex="2" />
                <Label fx:id="name" styleClass="info-value-text" text="小王" GridPane.columnIndex="1" />
                <Label fx:id="studentId" styleClass="info-value-text" text="09023101" GridPane.columnIndex="3" />
            	<DatePicker fx:id="expectedResumptionDate" styleClass="my-date" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            	<Label styleClass="info-key-text" text="开始休学日期：" GridPane.rowIndex="1" />
            	<Label styleClass="info-key-text" text="预计复学日期：" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            	<DatePicker fx:id="absenceStartDate" styleClass="my-date" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            	<Label styleClass="info-key-text" text="申请原因：" GridPane.rowIndex="2" />
            	<TextField fx:id="applicationReason" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>
    </children>
</VBox>
