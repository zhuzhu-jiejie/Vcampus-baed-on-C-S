<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<?import javafx.scene.control.*?>

<ScrollPane fx:id="scrollPane" fitToWidth="true" prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/student_status.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.vcampus.client.controller.AdminStudentProfileController">
   <content>
   	  <!-- 最外层的VBox容器 -->
      <VBox styleClass="background">
         <children>
                           
            <VBox styleClass="card-background">
               <children>
                  <HBox styleClass="card-title-bar">
                     <children>
                        <Label styleClass="card-title" text="学生列表" />
                     </children>
                  </HBox>
                  <GridPane hgap="5" style="-fx-padding: 5;" vgap="1">
            		<columnConstraints>
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
            		</columnConstraints>
            		<rowConstraints>
                		<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            		</rowConstraints>
            		<children>
                		<Label styleClass="info-key-text" text="按姓名：" GridPane.columnIndex="2" />
                		<Label styleClass="info-key-text" text="按学号：" />
            			<Label styleClass="info-key-text" text="按学院：" GridPane.rowIndex="1" />
            			<Label styleClass="info-key-text" text="按班级：" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            			<Label styleClass="info-key-text" text="按就读年级：" GridPane.rowIndex="2" />
            			<TextField fx:id="byName" styleClass="my-textarea" GridPane.columnIndex="3" />
            			<ComboBox fx:id="byCollege" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <TextField fx:id="byStudentId" styleClass="my-textarea" GridPane.columnIndex="1" />
                        <Label styleClass="info-key-text" text="按专业：" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <ComboBox fx:id="byMajor" styleClass="my-combo-box" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        <ComboBox fx:id="byGrade" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <ComboBox fx:id="byClassName" styleClass="my-combo-box" GridPane.columnIndex="3" GridPane.rowIndex="2" />
           			</children>
        		  </GridPane>
                  <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="50.0" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="retrieveButton" mnemonicParsing="false" onAction="#handleRetrieve" styleClass="my-button" text="检索" />
                        <Button fx:id="conditionClearButton" mnemonicParsing="false" onAction="#handleConditionClear" styleClass="my-button" text="清空条件" />
                     </children>
                  </HBox>
                  
                  <!-- 加载提示 -->
                  <HBox alignment="CENTER" prefHeight="30.0" spacing="10.0" style="-fx-padding: 0 5 5 5;">
                     <children>
                        <!-- 加载提示：初始隐藏，显示时用旋转图标增强视觉效果 -->
                        <Label fx:id="loadingLabel" text="加载中..." visible="false">
                           <graphic>
                              <ProgressIndicator prefHeight="16.0" prefWidth="16.0" style="-fx-progress-color: #2196f3;" />
                           </graphic>
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin>
                        </Label>
                        <!-- 错误/成功提示：初始隐藏，红色=错误，绿色=成功 -->
                        <Label fx:id="errorLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 13px;" text="" visible="false" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="studentList" styleClass="my-table-view">
                    <columns>
                      	<TableColumn fx:id="studentIdCol" prefWidth="110.0" text="学号" />
                      	<TableColumn fx:id="nameCol" prefWidth="124.0" text="姓名" />
                        <TableColumn fx:id="collegeCol" prefWidth="138.0" text="学院" />
                        <TableColumn fx:id="majorCol" prefWidth="122.0" text="专业" />
                        <TableColumn fx:id="gradeCol" prefWidth="104.0" text="就读年级" />
                        <TableColumn fx:id="classNameCol" prefWidth="109.0" text="班级" />
                    </columns>
                     <VBox.margin>
                        <Insets left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                  </TableView>
               </children>
            </VBox>
            
			         				                        <!-- 学籍状态信息卡片 -->
            <VBox styleClass="card-background">
               <children>
                  <HBox styleClass="card-title-bar">
                     <children>
                        <Label styleClass="card-title" text="学籍信息" />
                     </children>
                  </HBox>
                  <GridPane hgap="5" style="-fx-padding: 5;" vgap="1">
                     <children>
                        <Label styleClass="info-key-text" text="培养层级：" GridPane.rowIndex="5" />
                        <Label styleClass="info-key-text" text="学籍状态：" GridPane.rowIndex="6" />
                        <Label styleClass="info-key-text" text="入学日期：" GridPane.columnIndex="2" GridPane.rowIndex="6" />
                        <Label styleClass="info-key-text" text="学制：" GridPane.columnIndex="2" GridPane.rowIndex="5" />
                        <Label styleClass="info-key-text" text="就读年级：" GridPane.rowIndex="2" />
                        <Label styleClass="info-key-text" text="预期毕业日期：" GridPane.rowIndex="7" />
                        <Label styleClass="info-key-text" text="姓名：" />
                        <Label styleClass="info-key-text" text="学号：" GridPane.columnIndex="2" />
                        <Label styleClass="info-key-text" text="学院：" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
                        <Label styleClass="info-key-text" text="班级：" GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
                        <Label styleClass="info-key-text" text="专业：" GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
                        <Label styleClass="info-key-text" text="导师：" GridPane.halignment="RIGHT" GridPane.rowIndex="3" />
                        <Label styleClass="info-key-text" text="辅导员：" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
                        <ComboBox fx:id="college" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <ComboBox fx:id="major" styleClass="my-combo-box" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        <ComboBox fx:id="className" styleClass="my-combo-box" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                        <ComboBox fx:id="studentStatus" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <DatePicker fx:id="admissionDate" styleClass="my-date" GridPane.columnIndex="3" GridPane.rowIndex="6" />
                        <DatePicker fx:id="expectedGraduationDate" styleClass="my-date" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                        <ComboBox fx:id="grade" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <TextField fx:id="duration" styleClass="my-textarea" GridPane.columnIndex="3" GridPane.rowIndex="5" />
                        <TextField fx:id="counsellor" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <ComboBox fx:id="levelOfStudy" prefWidth="150.0" styleClass="my-combo-box" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <TextField fx:id="mentor" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <TextField fx:id="name" styleClass="my-textarea" GridPane.columnIndex="1" />
                        <TextField fx:id="studentId" styleClass="my-textarea" GridPane.columnIndex="3" />
                        <Label styleClass="info-key-text" text="导师ID：" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                        <Label styleClass="info-key-text" text="辅导员ID：" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                        <TextField fx:id="mentorId" styleClass="my-textarea" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                        <TextField fx:id="counsellorId" styleClass="my-textarea" GridPane.columnIndex="3" GridPane.rowIndex="4" />
                     </children>
                     <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                  </GridPane>
                  
                                    <!-- 加载提示 -->
                  <HBox alignment="CENTER" prefHeight="30.0" spacing="10.0" style="-fx-padding: 0 5 5 5;">
                     <children>
                        <!-- 加载提示：初始隐藏，显示时用旋转图标增强视觉效果 -->
                        <Label fx:id="loadingInfoLabel" text="加载中..." visible="false">
                           <graphic>
                              <ProgressIndicator prefHeight="16.0" prefWidth="16.0" style="-fx-progress-color: #2196f3;" />
                           </graphic>
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin>
                        </Label>
                        <!-- 错误/成功提示：初始隐藏，红色=错误，绿色=成功 -->
                        <Label fx:id="errorInfoLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 13px;" text="" visible="false" />
                     </children>
                  </HBox>
                  
                  <HBox alignment="CENTER_RIGHT" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="addButton" layoutX="398.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleAdd" styleClass="my-button" text="添加" />
                        <Button fx:id="deselectButton" mnemonicParsing="false" onAction="#handleDeselect" styleClass="my-button" text="取消选中" />
                        <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#handleConfirmChange" styleClass="my-button" text="确认更改" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
         </children></VBox>
   </content>
</ScrollPane>
