<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@../css/admin_order_manager.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
 fx:controller="seu.vcampus.client.controller.AdminOrderManagerController">
    <top>
        <!-- 顶部导航栏 -->
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="订单管理" />
            
            <HBox spacing="15" style="-fx-padding: 0 0 0 30;">
                <Button mnemonicParsing="false" onAction="#handleNavigateToProducts" style="-fx-nav-button;" text="商品管理" />
                <Button mnemonicParsing="false" onAction="#handleNavigateToUsers" style="-fx-nav-button;" text="用户管理" />
                <Button mnemonicParsing="false" onAction="#handleNavigateToReports" style="-fx-nav-button;" text="报表统计" />
                <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-nav-button;" text="退出登录" />
            </HBox>
        </HBox>
        
        <!-- 搜索和筛选栏 -->
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #34495e; -fx-padding: 15;">
            <TextField fx:id="searchField" promptText="搜索订单..." style="-fx-search-field;" />
            <ComboBox fx:id="statusFilter" promptText="选择状态" style="-fx-filter-combo;" />
            <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-filter-button;" text="搜索" />
            <Button mnemonicParsing="false" onAction="#handleClearFilter" style="-fx-filter-button;" text="清除筛选" />
        </HBox>
    </top>
    
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <!-- 订单表格 -->
            <VBox spacing="10" style="-fx-pref-width: 700;">
                <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 16;" text="订单列表" />
                <TableView fx:id="ordersTable" style="-fx-orders-table;">
                    <columns>
                        <TableColumn fx:id="colOrderId" text="订单号" />
                        <TableColumn fx:id="colUserId" text="用户ID" /> <!-- 新增用户ID列 -->
                        <TableColumn fx:id="colOrderDate" text="下单时间" />
                        <TableColumn fx:id="colOrderStatus" text="状态" />
                        <TableColumn fx:id="colOrderTotal" text="总金额" />
                    </columns>
                </TableView>
            </VBox>
            
            <!-- 订单详情和操作 -->
            <VBox spacing="15" style="-fx-pref-width: 400;">
                <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 16;" text="订单详情" />
                
                <TextArea fx:id="orderDetailsArea" editable="false" style="-fx-order-details;" />
                
                <HBox spacing="10">
                    <!-- 移除了标记付款按钮 -->
                    <Button fx:id="shipOrderButton" mnemonicParsing="false" onAction="#handleShipOrder" style="-fx-primary-button;" text="标记发货" />
                    <Button fx:id="completeOrderButton" mnemonicParsing="false" onAction="#handleCompleteOrder" style="-fx-primary-button;" text="完成订单" />
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>