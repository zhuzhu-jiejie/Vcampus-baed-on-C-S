<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<?import javafx.scene.control.*?>

<ScrollPane fx:id="scrollPane" fitToWidth="true" prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/student_status.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="seu.vcampus.client.controller.AdminGradesController">
   <content>
   	  <!-- 最外层的VBox容器 -->
      <VBox styleClass="background">
         <children>
            <VBox styleClass="card-background">
               <children>
                  <HBox styleClass="card-title-bar">
                     <children>
                        <Label styleClass="card-title" text="全校课程" />
                     </children>
                  </HBox>
                  <GridPane hgap="5" style="-fx-padding: 5;" vgap="1">
            		<columnConstraints>
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
            		</columnConstraints>
            		<rowConstraints>
                		<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            		</rowConstraints>
            		<children>
                		<Label styleClass="info-key-text" text="选择学期：" />
            			<Label styleClass="info-key-text" text="按课程编号：" GridPane.rowIndex="1" />
            			<Label styleClass="info-key-text" text="按任课老师：" GridPane.rowIndex="2" />
                        <Label styleClass="info-key-text" text="按课程名称：" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <TextField fx:id="byCourseId" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <TextField fx:id="byCourseName" styleClass="my-textarea" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        <TextField fx:id="byTeacher" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label styleClass="info-key-text" text="按状态：" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <ComboBox fx:id="byStatus" styleClass="my-combo-box" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                        <ComboBox fx:id="bySemester" prefWidth="150.0" styleClass="my-combo-box" GridPane.columnIndex="1" />
            		</children>
        		</GridPane>
                  <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="50.0" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="retrieveCourse" mnemonicParsing="false" onAction="#handleRetrieveCourse" styleClass="my-button" text="检索" />
                        <Button fx:id="conditionClearButton" mnemonicParsing="false" onAction="#handleConditionClear" styleClass="my-button" text="清空条件" />
                     </children>
                  </HBox>
                  
                                    <!-- 加载提示 -->
                  <HBox alignment="CENTER" prefHeight="30.0" spacing="10.0" style="-fx-padding: 0 5 5 5;">
                     <children>
                        <!-- 加载提示：初始隐藏，显示时用旋转图标增强视觉效果 -->
                        <Label fx:id="loadingCourseLabel" text="加载中..." visible="false">
                           <graphic>
                              <ProgressIndicator prefHeight="16.0" prefWidth="16.0" style="-fx-progress-color: #2196f3;" />
                           </graphic>
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin>
                        </Label>
                        <!-- 错误/成功提示：初始隐藏，红色=错误，绿色=成功 -->
                        <Label fx:id="errorCourseLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 13px;" text="" visible="false" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="courseList" styleClass="my-table-view">
                    <columns>
                      	<TableColumn fx:id="semesterCol" prefWidth="95.0" text="学期" />
                      	<TableColumn fx:id="courseIdCol" prefWidth="127.0" text="课程编号" />
                        <TableColumn fx:id="courseNameCol" prefWidth="119.0" text="课程名称" />
                        <TableColumn fx:id="teacherCol" prefWidth="117.0" text="任课教师" />
                        <TableColumn fx:id="scheduleCol" prefWidth="132.0" text="上课时段" />
                        <TableColumn fx:id="statusCol" prefWidth="117.0" text="状态" />
                    </columns>
                     <VBox.margin>
                        <Insets bottom="8.0" left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                  </TableView>
               </children>
            </VBox>
            
            <VBox styleClass="card-background">
               <children>
                  <HBox styleClass="card-title-bar">
                     <children>
                        <Label styleClass="card-title" text="学生列表" />
                     </children>
                  </HBox>
                  <GridPane hgap="5" style="-fx-padding: 5;" vgap="1">
            		<columnConstraints>
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
                		<ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="119.5" />
                		<ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" maxWidth="300" minWidth="10.0" prefWidth="239.0" />
            		</columnConstraints>
            		<rowConstraints>
                		<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            			<RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            		</rowConstraints>
            		<children>
                		<Label styleClass="info-key-text" text="当前课程：" />
            			<Label styleClass="info-key-text" text="姓名：" GridPane.rowIndex="1" />
            			<Label styleClass="info-key-text" text="平时成绩：" GridPane.rowIndex="2" />
            			<Label fx:id="selectedCourse" styleClass="info-value-text" text="未选中" GridPane.columnIndex="1" />
                        <Label styleClass="info-key-text" text="学号：" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <TextField fx:id="name" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <TextField fx:id="studentId" styleClass="my-textarea" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        <TextField fx:id="regularGrades" styleClass="my-textarea" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <TextField fx:id="finalGrades" styleClass="my-textarea" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                        <Label styleClass="info-key-text" text="期末成绩：" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <Label styleClass="info-key-text" text="任课老师：" GridPane.columnIndex="2" />
                        <Label fx:id="selectedTeacher" styleClass="info-value-text" text="未选中" GridPane.columnIndex="3" />
            		</children>
        		</GridPane>
                  <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="50.0" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="deselectButton" mnemonicParsing="false" onAction="#handleDeselect" styleClass="my-button" text="取消选中" />
                        <Button fx:id="clearButton" mnemonicParsing="false" onAction="#handleClear" styleClass="my-button" text="清空" />
                        <Button fx:id="reviseGrade" layoutX="563.0" layoutY="16.0" mnemonicParsing="false" onAction="#handleRevise" styleClass="my-button" text="修改成绩" />
                     </children>
                  </HBox>
                  
                                    <!-- 加载提示 -->
                  <HBox alignment="CENTER" prefHeight="30.0" spacing="10.0" style="-fx-padding: 0 5 5 5;">
                     <children>
                        <!-- 加载提示：初始隐藏，显示时用旋转图标增强视觉效果 -->
                        <Label fx:id="loadingGradesLabel" text="加载中..." visible="false">
                           <graphic>
                              <ProgressIndicator prefHeight="16.0" prefWidth="16.0" style="-fx-progress-color: #2196f3;" />
                           </graphic>
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin>
                        </Label>
                        <!-- 错误/成功提示：初始隐藏，红色=错误，绿色=成功 -->
                        <Label fx:id="errorGradesLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 13px;" text="" visible="false" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="gradesList" styleClass="my-table-view">
                    <columns>
                      	<TableColumn fx:id="studentIdCol" prefWidth="110.0" text="学号" />
                      	<TableColumn fx:id="nameCol" prefWidth="124.0" text="姓名" />
                        <TableColumn fx:id="majorCol" prefWidth="122.0" text="专业" />
                        <TableColumn fx:id="regularGradesCol" prefWidth="122.0" text="平时成绩" />
                        <TableColumn fx:id="finalGradesCol" prefWidth="122.0" text="期末成绩" />
                        <TableColumn fx:id="totalGradesCol" prefWidth="122.0" text="总成绩" />
                    </columns>
                     <VBox.margin>
                        <Insets bottom="8.0" left="5.0" right="5.0" top="5.0" />
                     </VBox.margin>
                  </TableView>
                  <HBox alignment="CENTER_RIGHT" styleClass="card-bottom-bar">
                     <children>
                        <Button fx:id="passButton" mnemonicParsing="false" onAction="#handlePass" styleClass="my-button" text="通过审核" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
         </children></VBox>
   </content>
</ScrollPane>
