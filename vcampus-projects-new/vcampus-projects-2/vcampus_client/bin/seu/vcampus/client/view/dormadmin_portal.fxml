<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="650" minWidth="950" prefHeight="650" prefWidth="950" stylesheets="@../css/dormadmin_portal.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
fx:controller="seu.vcampus.client.controller.DormAdminPortalController">
    <!-- 顶部标题栏：不变 -->
    <top>
        <HBox fx:id="titleBar" prefHeight="50.0" styleClass="title-bar" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="vcampusButton" mnemonicParsing="false" styleClass="vcampus-title" text="V-Campus">
                    <padding>
                        <Insets left="10.0" right="10.0" />
                    </padding>
                </Button>
                <HBox alignment="CENTER_RIGHT" prefHeight="100.0" spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="minimizeButton" mnemonicParsing="false" onAction="#handleMinimize" styleClass="minimize-button">
                            <graphic>
                                <SVGPath content="M6,12 H14" styleClass="minimize-icon" />
                            </graphic>
                        </Button>
                        <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" styleClass="close-button">
                            <graphic>
                                <SVGPath content="M7,7 L13,13 M13,7 L7,13" styleClass="close-icon" />
                            </graphic>
                        </Button>
                    </children>
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </HBox>
            </children>
        </HBox>
    </top>
    
    <!-- 左侧核心修改：用StackPane让两个侧边栏重叠，固定宽度150px（无空白） -->
    <left>
        <StackPane fx:id="leftStack" prefWidth="150.0" prefHeight="600.0" styleClass="left-stack">
            <!-- 下层：功能侧边栏（默认显示，加载子功能） -->
            <VBox fx:id="sidebarContainer" prefWidth="150.0" prefHeight="600.0" styleClass="sidebar" VBox.vgrow="ALWAYS" />
            <!-- 上层：应用侧边栏（默认隐藏，点击V-Campus显示，覆盖功能侧边栏） -->
            <VBox fx:id="appSidebar" prefWidth="150.0" prefHeight="600.0" styleClass="app-sidebar" visible="false" />
        </StackPane>
    </left>
    
    <!-- 中间内容区：不变 -->
    <center>
        <VBox fx:id="contentArea" prefHeight="600.0" prefWidth="800.0" styleClass="content-area" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS" />
    </center>
</BorderPane>